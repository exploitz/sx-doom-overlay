diff --git a/doomgeneric/d_main.c b/doomgeneric/d_main.c
index 9012e5f..45bb22a 100644
--- a/doomgeneric/d_main.c
+++ b/doomgeneric/d_main.c
@@ -1066,23 +1066,15 @@ void PrintGameVersion(void)
 
 static void D_Endoom(void)
 {
-    byte *endoom;
-
-    // Don't show ENDOOM if we have it disabled, or we're running
-    // in screensaver or control test mode. Only show it once the
-    // game has actually started.
-
-    if (!show_endoom || !main_loop_started
-     || screensaver_mode || M_CheckParm("-testcontrols") > 0)
-    {
-        return;
-    }
-
-    endoom = W_CacheLumpName(DEH_String("ENDOOM"), PU_STATIC);
-
-    I_Endoom(endoom);
-
-	exit(0);
+    /* sx-doom-overlay: original implementation called exit(0) at the bottom,
+     * which kills the entire nx-ovlloader sysmodule when the user picks
+     * "Quit Game" from the in-game menu (D_Endoom is registered via I_AtExit
+     * and runs from I_Quit's atexit loop). Without ORIGCODE the I_Endoom call
+     * was a no-op anyway, so the entire function only existed to crash us at
+     * quit time with fatal 2347-0004. Make it a complete no-op; the
+     * longjmp(g_doom_error_jmp, 2) at the end of I_Quit (patches/0002) handles
+     * the actual clean shutdown back to our setjmp recovery. */
+    return;
 }
 
 #if ORIGCODE
