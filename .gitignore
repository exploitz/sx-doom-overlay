# Build artifacts. Per-platform namespaced dirs (build-win, build-linux,
# out-win, out-linux, etc) so the same checkout can be built from
# multiple shells without cross-contamination.
build/
build-*/
out/
out-*/
dist/
*.elf
*.nro
*.nso
*.npdm
*.nacp
*.ovl
*.nsp
*.d
*.o

# devkitPro intermediates
*.specs

# Patch sentinel — produced by `make patches`, blown away on `make clean`
lib/doomgeneric/.patched

# WAD files anywhere under data/ — copyrighted IWADs (DOOM, CHEX),
# BSD-3 (Freedoom), GENMIDI instrument banks. Drop your own copies
# into data/wads/. Not tracked in git. The .gitkeep keeps the dir.
data/*.wad
data/wads/*.wad
!data/wads/.gitkeep

# Music pack — third-party recordings (Brandon Blume Roland SC-55 pack,
# Arachnosoft Chex pack) or script-rendered output from
# scripts/extract-wad-music.py. Not tracked.
data/music/**
!data/music/.gitkeep
data/test.ogg

# Desktop test outputs
tests/desktop/out/
tests/desktop/*.wav
tests/desktop/*.ppm
tests/desktop/*.png

# Editor / OS / IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# Tooling intermediates that some editors / language servers spit out at the
# repo root — clangd, ctags, etc. Not worth checking in.
compile_commands.json
.cache/
tags
.tags
cscope.*

# Local environment overrides — never commit secrets or per-machine paths.
.env
.env.local
.env.*.local

# Generic stray scratch files
*.tmp
*.bak
*.orig
*.rej

# Pilot internals
.pilot/

# Diagnostic pulls from sync-sd.sh (trace.log + crash reports per timestamp)
diagnostics/

# Legacy reference clones (deleted in Task 1, but ignore in case they're re-cloned)
Ultrahand-Overlay/
_reference/

# Reference clones from session research (UltraGB audio approach,
# chocolate-doom OPL/i_oplmusic source). Vendored copies live in source/opl/.
lib/UltraGB/
lib/chocolate-doom/

# Per-session crash dumps + trace.log copied off the SD card for debugging
logs/
dumps/

# Accidental scratch files
docs/d-users-*
